{
  "version": "1.14.0",
  "name": "hangar-directories",
  "publisher": "clandher",
  "displayName": "Hangar",
  "description": "Your local projects, always within reach.",
  "license": "MIT",
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "projects",
    "dashboard",
    "launcher",
    "workspace"
  ],
  "homepage": "https://github.com/clandher/hangar",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "hangar.open",
        "title": "Open Hangar"
      },
      {
        "command": "hangar.resetStorage",
        "title": "Hangar: Reset Storage"
      }
    ],
    "keybindings": [
      {
        "command": "hangar.open",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "Hangar",
      "properties": {
        "hangar.chipAction": {
          "type": "string",
          "default": "new-window",
          "enum": [
            "new-window",
            "replace"
          ],
          "enumDescriptions": [
            "Open in a new VSCode window",
            "Replace current window"
          ],
          "description": "What the open chip/button does."
        },
        "hangar.clickAction": {
          "type": "string",
          "default": "replace",
          "enum": [
            "new-window",
            "replace"
          ],
          "enumDescriptions": [
            "Open in a new VSCode window",
            "Replace current window"
          ],
          "description": "What ⌘+click (or Ctrl+click) does."
        },
        "hangar.showOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Show Hangar dashboard when VSCode starts."
        },
        "hangar.maxRecents": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 20,
          "description": "Number of recent projects to show."
        },
        "hangar.cardSize": {
          "type": "string",
          "default": "normal",
          "enum": [
            "compact",
            "normal",
            "large"
          ],
          "description": "Size of project cards in the dashboard."
        },
        "hangar.showGitInfo": {
          "type": "boolean",
          "default": true,
          "description": "Show git branch, last commit, and commit badge on cards."
        },
        "hangar.reusePanel": {
          "type": "boolean",
          "default": true,
          "description": "Reveal existing Hangar panel instead of opening a new one."
        },
        "hangar.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show project count in the status bar."
        },
        "hangar.baseBranch": {
          "type": "string",
          "default": "",
          "description": "Branch to compare ahead/behind against (e.g. 'develop', 'main'). Leave empty to use each repo's upstream tracking branch."
        },
        "hangar.runners": {
          "type": "array",
          "description": "Custom scan commands that run per-project and display results on cards.",
          "default": [
            {
              "name": "npm outdated",
              "command": "npm outdated --json 2>/dev/null; true",
              "resultType": "json-count",
              "label": "outdated",
              "warnAt": 1,
              "stacks": ["node"]
            },
            {
              "name": "npm audit",
              "command": "npm audit --json 2>/dev/null || true",
              "resultType": "json-field",
              "field": "metadata.vulnerabilities.total",
              "label": "vulns",
              "warnAt": 1,
              "errorAt": 5,
              "stacks": ["node"]
            },
            {
              "name": "ncu",
              "command": "npx --yes npm-check-updates --jsonUpgraded 2>/dev/null",
              "resultType": "json-count",
              "label": "upgradeable",
              "warnAt": 1,
              "stacks": ["node"]
            },
            {
              "name": "pip outdated",
              "command": "pip list --outdated --format=json 2>/dev/null",
              "resultType": "json-count",
              "label": "outdated",
              "warnAt": 1,
              "stacks": ["python"]
            },
            {
              "name": "mvn analyze",
              "command": "mvn dependency:analyze 2>&1 | grep '\\[WARNING\\]'",
              "resultType": "count",
              "label": "dep warnings",
              "warnAt": 1,
              "stacks": ["java", "gradle"]
            },
            {
              "name": "git stashes",
              "command": "git stash list 2>/dev/null",
              "resultType": "count",
              "label": "stashes",
              "warnAt": 1
            },
            {
              "name": "todos",
              "command": "grep -rlE 'TODO|FIXME' --include='*.ts' --include='*.js' --include='*.py' --include='*.java' --include='*.go' . 2>/dev/null",
              "resultType": "count",
              "label": "files w/ TODOs",
              "warnAt": 1
            }
          ],
          "items": {
            "type": "object",
            "required": ["name", "command", "resultType"],
            "properties": {
              "name": { "type": "string", "description": "Display name shown in the scan menu." },
              "command": { "type": "string", "description": "Shell command to run. Use {path} as placeholder for the project path." },
              "resultType": {
                "type": "string",
                "enum": ["count", "pass-fail", "json-count", "json-field", "text"],
                "description": "How to parse stdout: count (integer), pass-fail (exit code), json-count (keys/items), json-field (dot-path), text (first line)."
              },
              "field": { "type": "string", "description": "Dot-notation field path for json-field type (e.g. metadata.vulnerabilities.total)." },
              "label": { "type": "string", "description": "Suffix shown after the number (e.g. 'vulns')." },
              "warnAt": { "type": "number", "description": "Show yellow warning when value >= this." },
              "errorAt": { "type": "number", "description": "Show red error when value >= this." },
              "stacks": { "type": "array", "items": { "type": "string" }, "description": "Only run on projects with matching stack (e.g. ['node', 'python']). Omit to run on all." }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clandher/hangar"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
